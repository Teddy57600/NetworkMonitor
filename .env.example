# Nom du conteneur
NETWORKMONITOR_CONTAINER_NAME=networkmonitor

# Politique de redémarrage Docker
NETWORKMONITOR_RESTART_POLICY=unless-stopped

# Contexte de build et Dockerfile
NETWORKMONITOR_BUILD_CONTEXT=.
NETWORKMONITOR_DOCKERFILE=NetworkMonitor/Dockerfile

# Fichier YAML monté dans le conteneur
NETWORKMONITOR_YAML_SOURCE=./config.yaml
NETWORKMONITOR_CONFIG_PATH=/config/config.yaml

# Port HTTP exposé pour le tableau de bord web
NETWORKMONITOR_HTTP_PORT=8080

# Répertoire de persistance dans le conteneur et nom du volume Docker
NETWORKMONITOR_DATA_DIR=/data
NETWORKMONITOR_DATA_VOLUME=networkmonitor-data
