services:
  networkmonitor:
    build:
      context: ${NETWORKMONITOR_BUILD_CONTEXT:-.}
      dockerfile: ${NETWORKMONITOR_DOCKERFILE:-NetworkMonitor/Dockerfile}
    container_name: ${NETWORKMONITOR_CONTAINER_NAME:-networkmonitor}
    restart: ${NETWORKMONITOR_RESTART_POLICY:-unless-stopped}
    environment:
      DATA_DIR: ${NETWORKMONITOR_DATA_DIR:-/data}
      CONFIG_YAML_PATH: ${NETWORKMONITOR_CONFIG_PATH:-/config/config.yaml}
      DASHBOARD_AUTH_ENABLED: ${NETWORKMONITOR_DASHBOARD_AUTH_ENABLED:-false}
      DASHBOARD_AUTH_USERNAME: ${NETWORKMONITOR_DASHBOARD_AUTH_USERNAME:-}
      DASHBOARD_AUTH_PASSWORD: ${NETWORKMONITOR_DASHBOARD_AUTH_PASSWORD:-}
    ports:
      - ${NETWORKMONITOR_HTTP_PORT:-8080}:8080
    volumes:
      - ${NETWORKMONITOR_YAML_SOURCE:-./config.yaml}:${NETWORKMONITOR_CONFIG_PATH:-/config/config.yaml}:${NETWORKMONITOR_YAML_MOUNT_MODE:-rw}
      - ${NETWORKMONITOR_DATA_VOLUME:-networkmonitor-data}:${NETWORKMONITOR_DATA_DIR:-/data}

  watchtower:
    image: containrrr/watchtower:latest
    container_name: ${NETWORKMONITOR_WATCHTOWER_CONTAINER_NAME:-networkmonitor-watchtower}
    restart: unless-stopped
    command: --interval ${NETWORKMONITOR_WATCHTOWER_INTERVAL_SECONDS:-3600} --cleanup --label-enable
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock

volumes:
  ${NETWORKMONITOR_DATA_VOLUME:-networkmonitor-data}:
