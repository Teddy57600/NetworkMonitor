appVersion: "1.6.0"
snoozeDays: 3

# Les cibles définies ici s'ajoutent à celles fournies via PING_TARGETS et TCP_TARGETS.
# Les doublons sont supprimés automatiquement.

schedule:
  cron: "*/30 * * * * *"
  # intervalSeconds: 10

dashboard:
  refreshSeconds: 5

pushover:
  token: "your-pushover-token"
  user: "your-pushover-user"
  startupSound: "cosmic"
  shutdownSound: "falling"

monitoring:
  pingTargets:
    - 1.1.1.1
    - 8.8.8.8
  tcpTargets:
    - google.com:443
    - host: localhost
      port: 80
